# 复制为 .env 后按需修改。V0 默认全部走模板，无需任何配置。

# 是否启用本地 Ollama 生成解释（0=固定模板，1=Ollama）
USE_OLLAMA=0

# Ollama 服务地址与模型（USE_OLLAMA=1 时生效）
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_TIMEOUT=30
# 模型在显存中常驻时长，避免每次请求冷载入（实测 warm 后单次 ~0.8s）
OLLAMA_KEEP_ALIVE=10m
# 说明：代码里已对 qwen3 强制 think=False，否则 thinking 模式会让单次解释慢到 40s+
